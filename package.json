{
  "name": "gh-upload-sbom",
  "version": "4.1.0",
  "description": "Publishes BOMs to Dependency-Track from GitHub Actions",
  "main": "index.js",
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "version": "npm run build && git add dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DependencyTrack/gh-upload-sbom"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "3.0.1"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
